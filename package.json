{
  "name": "xpress-cli",
  "version": "0.1.0",
  "description": "Official CLI for the Creativiso Xpress public REST API",
  "bin": {
    "xpress": "dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "axios": "1.6.8",
    "chalk": "4.1.2",
    "cli-table3": "0.6.3",
    "commander": "12.0.0",
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.24",
    "@typescript-eslint/eslint-plugin": "7.0.2",
    "@typescript-eslint/parser": "7.0.2",
    "eslint": "8.56.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "typescript": "5.3.3"
  }
}
